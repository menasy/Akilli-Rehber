{
  "expo": {
    "name": "Akıllı Rehber",
    "slug": "akilli-rehber",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android-icon-foreground.png",
    "scheme": "akillirehber",
    "userInterfaceStyle": "light",

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akillirehber.app",

      "infoPlist": {
        "NSContactsUsageDescription": "Rehberinizdeki kişileri görüntülemek ve arama yapabilmek için erişim gereklidir.",
        "NSMicrophoneUsageDescription": "Kişileri sesli komutla arayabilmeniz için mikrofon erişimi gereklidir.",
        "NSSpeechRecognitionUsageDescription": "Sesli komutları algılayarak rehberde kişi aramak için kullanılır."
      }
    },

    "android": {
      "package": "com.akillirehber.app",
      "predictiveBackGestureEnabled": false,

      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.RECORD_AUDIO"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FFFFFF"
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Rehberdeki kişileri görüntülemek ve arama yapabilmek için erişim gereklidir."
        }
      ],
      "expo-font",
      "expo-speech-recognition"
    ]
  }
}