{
  "expo": {
    "name": "NasAi Akıllı Rehber",
    "slug": "nasAi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android-icon-foreground.png",
    "userInterfaceStyle": "light",
    "scheme": "nasai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.nasAi"
    },
    "android": {
      "package": "com.anonymous.nasAi",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Rehberinize erişmek için izin gerekiyor."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli arama için mikrofon erişimi gerekiyor."
        }
      ],
      "expo-font",
      "expo-asset"
    ]
  }
}
